# Pumble app secrets (from .pumbleapprc after first `pumble-cli create`)
PUMBLE_APP_ID=
PUMBLE_APP_KEY=
PUMBLE_APP_CLIENT_SECRET=
PUMBLE_APP_SIGNING_SECRET=

# Public URL of this addon (for pumble-cli pre-publish), e.g. https://pumble.secondmeet.example.com
PUMBLE_ADDON_PUBLIC_URL=

PUMBLE_ADDON_PORT=5500
