{
    "name": "pumble-mirotalk",
    "version": "1.0.0",
    "description": "Pumble addon for starting MiroTalk SFU video calls from chat",
    "main": "dist/main.js",
    "scripts": {
        "build": "tsc",
        "start": "node scripts/start-production.js",
        "start:prod": "npm run build && node scripts/start-production.js",
        "dev": "pumble-cli",
        "dev:direct": "npm run build && node scripts/start-local.js",
        "pre-publish": "npx pumble-cli pre-publish",
        "reinstall-oauth": "node scripts/reinstall-oauth.js",
        "sync-secrets": "node scripts/sync-pumble-secrets.js"
    },
    "keywords": [
        "pumble",
        "mirotalk",
        "webrtc",
        "video"
    ],
    "license": "AGPL-3.0",
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/node": "^22.10.0",
        "pumble-cli": "^1.0.2",
        "typescript": "^5.3.3"
    },
    "dependencies": {
        "pumble-sdk": "^1.0.2"
    }
}
